# Real-time Translator + Interview Assistant — environment template.
#
# Copy this file to `.env` (which is git-ignored) and fill in your own keys,
# OR enter the keys directly inside the app under Settings → Interview.
# The app reads these values from localStorage at runtime; the .env file is a
# convenience for advanced users who prefer to keep keys out of the UI.

# Soniox real-time STT + translation key (https://console.soniox.com)
SONIOX_API_KEY=your_soniox_api_key_here

# GPT API key for Combined Mode interview-answer generation.
# Use a key from OpenAI directly, or any OpenAI-compatible provider (Azure
# OpenAI, Groq, Together, OpenRouter, local llama-cpp-server, etc.) — point
# GPT_BASE_URL at the right base.
GPT_API_KEY=your_gpt_api_key_here
GPT_BASE_URL=https://api.openai.com/v1
GPT_MODEL=gpt-4o-mini
